generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum UserRole {
  USER
  ADMIN
  SEED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
}

enum MatchType {
  NORMAL
  FINAL
  SEMIFINAL
  QUARTERFINAL
  THIRD_PLACE_PLAYOFF
  ROUND_OF_32
  ROUND_OF_16
  GROUP_STAGE
  FRIENDLY
}

enum VoteOption {
  HOME
  DRAW
  AWAY
}

enum ReactionType {
  LIKE
  DISLIKE
  LAUGH
  ANGRY
}

//////////////////////
// USER
//////////////////////

model User {
  id       Int      @id @default(autoincrement())
  name     String
  email    String   @unique
  provider String
  password String?
  role     UserRole @default(USER)

  avatar_url      String? @default("")
  avatar_bg_color String? @default("")

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  team_id Int?
  team    Team? @relation(fields: [team_id], references: [id])

  votes                 MatchVote[]
  predictions           ScorePrediction[]
  comments              Comment[]
  commentReactions      CommentReaction[]
  adminMatchVotes       AdminMatchVote[]
  adminScorePredictions AdminScorePrediction[]

   //for Team Winner for League Season base on user+admin vote
  winnerVotes           WinnerVote[]
  adminWinnerVotes      AdminWinnerVote[]
}

//////////////////////
// LEAGUE
//////////////////////

model League {
  id         Int     @id @default(autoincrement())
  name       String
  country    String
  logo_url   String?
  slug       String  @unique
  sort_order Int     @default(0)

  recommended_gameweek Int?
  is_tournament        Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  teams   Team[]
  matches Match[]

  published Boolean @default(false)

  league_seasons LeagueSeason[]
}

//////////////////////
// TEAM
//////////////////////

model Team {
  id         Int     @id @default(autoincrement())
  name       String
  slug       String  @unique
  short_code String
  logo_url   String?
  country    String
  type       String
  venue      String?

  league_id Int
  league    League @relation(fields: [league_id], references: [id])

  users User[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  home_matches Match[] @relation("HomeTeam")
  away_matches Match[] @relation("AwayTeam")

  //Fifa world cup

  group_name     String?
  ranking        Int?
  participations Int?
  continental    String?
  isHost         Boolean @default(false)

  //for Team Winner for League Season base on user+admin vote
  winner_votes       WinnerVote[]
  admin_winner_votes AdminWinnerVote[]
  standings TeamStanding[]
}

//////////////////////
// TEAM STADNING
//////////////////////

model TeamStanding {
  id Int @id @default(autoincrement())

  team_id Int
  team    Team @relation(fields: [team_id], references: [id])

  league_season_id Int
  league_season    LeagueSeason @relation(fields: [league_season_id], references: [id])

  played          Int @default(0)
  won             Int @default(0)
  drawn           Int @default(0)
  lost            Int @default(0)
  goals_for       Int @default(0)
  goals_against   Int @default(0)
  goal_difference Int @default(0)
  points          Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([team_id, league_season_id])
}

//////////////////////
// MATCH
//////////////////////

model Match {
  id       Int      @id @default(autoincrement())
  kickoff  DateTime
  timezone String
  venue    String?

  slug String @unique

  status MatchStatus @default(SCHEDULED)
  type   MatchType   @default(NORMAL)

  allow_draw Boolean @default(true)
  big_match  Boolean @default(false)
  derby      Boolean @default(false)

  aggregate_home_score Int? // For two-legged ties
  aggregate_away_score Int? // For two-legged ties

  home_score Int?
  away_score Int?

  group_name String?

  published Boolean @default(false)

  home_team_name String?
  away_team_name String?
  home_team_id   Int
  home_team      Team    @relation("HomeTeam", fields: [home_team_id], references: [id])

  away_team_id Int
  away_team    Team @relation("AwayTeam", fields: [away_team_id], references: [id])

  league_id Int
  league    League @relation(fields: [league_id], references: [id])

  season_id Int
  season    Season @relation(fields: [season_id], references: [id])

  gameweek_id Int?
  gameweek    GameWeek? @relation(fields: [gameweek_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  votes          MatchVote[]
  predictions    ScorePrediction[]
  comments       Comment[]
  scoreOptions   ScoreOption[]
  adminMatchVote AdminMatchVote?
}

//////////////////////
// SEASON
//////////////////////

model Season {
  id Int @id @default(autoincrement())

  name String @unique
  year Int?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  league_seasons LeagueSeason[]

  game_weeks GameWeek[]
  matches    Match[]
}

//////////////////////
// LEAGUE SEASON
//////////////////////

model LeagueSeason {
  id Int @id @default(autoincrement())

  league_id Int
  season_id Int

  league League @relation(fields: [league_id], references: [id])
  season Season @relation(fields: [season_id], references: [id])

  created_at         DateTime          @default(now())
  winner_votes       WinnerVote[]
  admin_winner_votes AdminWinnerVote[]
  team_standings TeamStanding[]

  @@unique([league_id, season_id])
}

//////////////////////
// GameWeek
//////////////////////

model GameWeek {
  id Int @id @default(autoincrement())

  number Int

  name String?

  season_id Int
  season    Season @relation(fields: [season_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  matches Match[]

  @@unique([season_id, number])
}

//////////////////////
// MATCH VOTING
//////////////////////

model MatchVote {
  id Int @id @default(autoincrement())

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  match_id Int
  match    Match @relation(fields: [match_id], references: [id])

  vote VoteOption

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([user_id, match_id])
}

//for Team Winner for League Season base on user+admin vote
//////////////////////
// ADD WINNER VOTE 
//////////////////////

model WinnerVote {
  id Int @id @default(autoincrement())

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  league_season_id Int
  league_season    LeagueSeason @relation(fields: [league_season_id], references: [id])

  team_id Int
  team    Team @relation(fields: [team_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([user_id, league_season_id])
}

//for Team Winner for League Season base on user+admin vote
//////////////////////
// ADMIN WINNER VOTE 
//////////////////////

model AdminWinnerVote {
  id Int @id @default(autoincrement())

  league_season_id Int
  league_season    LeagueSeason @relation(fields: [league_season_id], references: [id])

  team_id Int
  team    Team @relation(fields: [team_id], references: [id])

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  vote_count Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([league_season_id, team_id])
}

//////////////////////
// SCORE OPTION
//////////////////////

model ScoreOption {
  id Int @id @default(autoincrement())

  match_id Int
  match    Match @relation(fields: [match_id], references: [id])

  home_score Int
  away_score Int

  created_at DateTime @default(now())

  votes                  ScorePrediction[]
  admin_score_prediction AdminScorePrediction?

  @@unique([match_id, home_score, away_score])
}

//////////////////////
// SCORE PREDICTION
//////////////////////

model ScorePrediction {
  id Int @id @default(autoincrement())

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  match_id Int
  match    Match @relation(fields: [match_id], references: [id])

  score_option_id Int
  score_option    ScoreOption @relation(fields: [score_option_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([user_id, match_id])
}

//////////////////////
// ADMIN MATCH VOTE
//////////////////////

model AdminMatchVote {
  id Int @id @default(autoincrement())

  match_id Int   @unique
  match    Match @relation(fields: [match_id], references: [id])

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  home_votes Int @default(0)
  draw_votes Int @default(0)
  away_votes Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

//////////////////////
// ADMIN SCORE PREDICTION
//////////////////////

model AdminScorePrediction {
  id Int @id @default(autoincrement())

  score_option_id Int
  score_option    ScoreOption @relation(fields: [score_option_id], references: [id])

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  vote_count Int @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([score_option_id])
}

//////////////////////
// Comment
//////////////////////

model Comment {
  id Int @id @default(autoincrement())

  match_id Int
  match    Match @relation(fields: [match_id], references: [id])

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  text String

  parent_id Int?
  parent    Comment?  @relation("CommentReplies", fields: [parent_id], references: [id])
  replies   Comment[] @relation("CommentReplies")

  reactions CommentReaction[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

//////////////////////
// Comment Reaction
//////////////////////

model CommentReaction {
  id Int @id @default(autoincrement())

  comment_id Int
  comment    Comment @relation(fields: [comment_id], references: [id])

  user_id Int
  user    User @relation(fields: [user_id], references: [id])

  reaction ReactionType

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([comment_id, user_id])
}
